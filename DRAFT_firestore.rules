rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Phase 4: Validation Blueprints
    function isValidTransaction(data) {
      return data.amount is number 
        && data.amount > 0
        && data.type in ['income', 'expense']
        && data.categoryId is string && data.categoryId.size() <= 64
        && data.description is string && data.description.size() <= 500
        && data.date is string && data.date.matches('^\\d{4}-\\d{2}-\\d{2}$')
        && data.ownerId == request.auth.uid
        && data.keys().hasAll(['amount', 'type', 'categoryId', 'description', 'date', 'ownerId', 'createdAt', 'updatedAt'])
        && data.keys().size() == 8;
    }

    match /transactions/{transactionId} {
      allow get: if isEmailVerified() && isOwner(existing().ownerId) && isValidId(transactionId);
      
      // 8. Secure List Queries
      allow list: if isEmailVerified() && resource.data.ownerId == request.auth.uid;

      allow create: if isEmailVerified() 
        && isValidTransaction(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;

      allow update: if isEmailVerified() 
        && isOwner(existing().ownerId)
        && isValidTransaction(incoming())
        && incoming().ownerId == existing().ownerId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && (
          // Action: General Update
          incoming().diff(existing()).affectedKeys().hasOnly(['amount', 'type', 'categoryId', 'description', 'date', 'updatedAt'])
        );

      allow delete: if isEmailVerified() && isOwner(existing().ownerId);
    }
  }
}
